{
  "name": "procurement-platform",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm db:generate && turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm db:generate && turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "db:generate": "pnpm --filter @procurement/database prisma generate",
    "db:migrate": "pnpm --filter @procurement/database prisma migrate deploy",
    "db:validate": "pnpm --filter @procurement/database prisma validate",
    "audit:deps": "pnpm audit --audit-level high"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.0",
      "multer": "2.2.0",
      "vite": "6.4.3"
    }
  }
}
