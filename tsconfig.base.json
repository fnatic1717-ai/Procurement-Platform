{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@procurement/shared": ["packages/shared/src"],
      "@procurement/config": ["packages/config/src"],
      "@procurement/database": ["packages/database/src"],
      "@procurement/ui": ["packages/ui/src"]
    }
  }
}
