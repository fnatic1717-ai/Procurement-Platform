generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model Tenant { id String @id @default(uuid()) @db.Uuid name String slug String @unique status String @default("active") createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") settings TenantSettings? memberships TenantMembership[] @@map("tenants") }
model TenantSettings { id String @id @default(uuid()) @db.Uuid tenantId String @unique @map("tenant_id") @db.Uuid settings Json @default("{}") createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") tenant Tenant @relation(fields:[tenantId], references:[id]) @@map("tenant_settings") }
model User { id String @id @default(uuid()) @db.Uuid email String @unique displayName String @map("display_name") subject String? @unique actorType String @default("internal_user") @map("actor_type") createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") memberships TenantMembership[] @@map("users") }
model TenantMembership { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid userId String @map("user_id") @db.Uuid status String @default("active") memberType String @default("internal") @map("member_type") createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") tenant Tenant @relation(fields:[tenantId], references:[id]) user User @relation(fields:[userId], references:[id]) @@unique([tenantId,userId]) @@index([tenantId,status]) @@map("tenant_memberships") }
model Role { id String @id @default(uuid()) @db.Uuid tenantId String? @map("tenant_id") @db.Uuid code String name String description String? createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@unique([tenantId,code]) @@map("roles") }
model Permission { id String @id @default(uuid()) @db.Uuid code String @unique description String createdAt DateTime @default(now()) @map("created_at") @@map("permissions") }
model RolePermission { roleId String @map("role_id") @db.Uuid permissionId String @map("permission_id") @db.Uuid createdAt DateTime @default(now()) @map("created_at") @@id([roleId,permissionId]) @@map("role_permissions") }
model UserRoleAssignment { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid userId String @map("user_id") @db.Uuid roleId String @map("role_id") @db.Uuid scopeType String @default("tenant") @map("scope_type") scopeId String? @map("scope_id") @db.Uuid createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") @@unique([tenantId,userId,roleId,scopeType,scopeId]) @@map("user_role_assignments") }
model OrganizationUnit { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid code String name String parentId String? @map("parent_id") @db.Uuid createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@unique([tenantId,code]) @@map("organization_units") }
model CostCenter { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid code String name String active Boolean @default(true) createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@unique([tenantId,code]) @@map("cost_centers") }
model Location { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid code String name String address Json? createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@unique([tenantId,code]) @@map("locations") }
model AuditEvent { id String @id @default(uuid()) @db.Uuid tenantId String? @map("tenant_id") @db.Uuid actorId String? @map("actor_id") @db.Uuid action String objectType String @map("object_type") objectId String? @map("object_id") @db.Uuid correlationId String @map("correlation_id") metadata Json? priorState Json? @map("prior_state") resultingState Json? @map("resulting_state") createdAt DateTime @default(now()) @map("created_at") @@index([tenantId,createdAt]) @@map("audit_events") }
model FileObject { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid storageKey String @unique @map("storage_key") filename String mimeType String @map("mime_type") sizeBytes BigInt @map("size_bytes") checksumSha256 String @map("checksum_sha256") uploaderId String @map("uploader_id") @db.Uuid classification String uploadState String @default("pending") @map("upload_state") scanStatus String @default("pending") @map("scan_status") retentionUntil DateTime? @map("retention_until") createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([tenantId,uploadState]) @@map("file_objects") }
model FileLink { id String @id @default(uuid()) @db.Uuid tenantId String @map("tenant_id") @db.Uuid fileObjectId String @map("file_object_id") @db.Uuid objectType String @map("object_type") objectId String @map("object_id") @db.Uuid createdBy String? @map("created_by") @db.Uuid createdAt DateTime @default(now()) @map("created_at") @@index([tenantId,objectType,objectId]) @@map("file_links") }
